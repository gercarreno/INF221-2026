# ─────────────────────────────────────────────
# C / C++ build artifacts
# ─────────────────────────────────────────────
*.o
*.obj
*.a
*.so
*.out
*.exe
*.d

# Compiled binaries
**/bin/
**/build/

# ─────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
.venv/
env/
venv/

# ─────────────────────────────────────────────
# Generated data — keep folder structure via .gitkeep,
# but ignore everything produced at runtime
# ─────────────────────────────────────────────

# Measurements / timing output
**/data/measurements/*
!**/data/measurements/.gitkeep

# Generated plots
**/data/plots/*
!**/data/plots/.gitkeep

# Matrix multiplication I/O (tarea1)
**/data/matrix_input/*
!**/data/matrix_input/.gitkeep

**/data/matrix_output/*
!**/data/matrix_output/.gitkeep

# Sorting I/O (tarea1)
**/data/array_input/*
!**/data/array_input/.gitkeep

**/data/array_output/*
!**/data/array_output/.gitkeep

# Generic inputs / outputs (tarea2 and future tareas)
**/data/inputs/*
!**/data/inputs/.gitkeep

**/data/outputs/*
!**/data/outputs/.gitkeep

# ─────────────────────────────────────────────
# LaTeX auxiliary / intermediate files
# ─────────────────────────────────────────────
*.aux
*.log
*.lof
*.lot
*.fls
*.toc
*.fmt
*.fot
*.cb
*.cb2
*.dvi
*.xdv
*.blg
*.bbl
*.bcf
*.run.xml
*.synctex.gz
*.synctex\(busy\)
*.fdb_latexmk
*.snm
*.nav
*.vrb
*.glg
*.glo
*.gls
*.glsdefs
*.idx
*.ilg
*.ind
*.ist
*.maf
*.mlf
*.mlt
*.mtc
*.mtc[0-9]
*.mw
**/report/_minted/

# Ignore ALL compiled PDFs that LaTeX regenerates
**/report/*.pdf
**/assignment_statement/*.pdf

# Explicitly keep the PDFs you want tracked
# (uncomment when you are ready to commit a final version)
# !tarea1/report/report.pdf
# !tarea2/report/report.pdf
# !tarea2/assignment_statement/assignment-2.pdf

# ─────────────────────────────────────────────
# VS Code
# ─────────────────────────────────────────────
.vscode/*
!.vscode/c_cpp_properties.json

# ─────────────────────────────────────────────
# OS-generated files
# ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ─────────────────────────────────────────────
# Editor / IDE temporary files
# ─────────────────────────────────────────────
*~
*.swp
*.swo
*.bak
*.tmp

# ─────────────────────────────────────────────
# LaTeX error saves (editor artifacts)
# ─────────────────────────────────────────────
*.bbl-SAVE-ERROR
