# ─────────────────────────────────────────────
#  C / C++ build artifacts
# ─────────────────────────────────────────────
*.o
*.obj
*.a
*.so
*.out
*.exe
*.d

# Compiled binaries — ignore bin/ or build/ anywhere under any tarea
**/code/**/bin/
**/code/**/build/

# ─────────────────────────────────────────────
#  Python
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
env/
venv/

# Generated data & plots — covers any tarea/project layout
**/code/**/data/measurements/
**/code/**/data/plots/

# ─────────────────────────────────────────────
#  LaTeX auxiliary files
# ─────────────────────────────────────────────
*.aux
*.log
*.lof
*.lot
*.fls
*.out
*.toc
*.fmt
*.fot
*.cb
*.cb2
*.dvi
*.xdv
*.blg
*.bbl
*.bcf
*.run.xml
*.synctex.gz
*.synctex(busy)
*.fdb_latexmk
*.snm
*.nav
*.vrb
*.glg
*.glo
*.gls
*.glsdefs
*.idx
*.ilg
*.ind
*.ist
*.maf
*.mlf
*.mlt
*.mtc
*.mtc[0-9]
*.mw
**/report/_minted*/
# Ignore compiled PDFs in report and assignment folders (regenerated by LaTeX)
**/report/*.pdf
**/assignment_statement/*.pdf
# To track a specific PDF, uncomment and adjust:
# !tarea1/report/report.pdf
# !tarea2/assignment_statement/assignment-2.pdf

# ─────────────────────────────────────────────
#  VS Code
# ─────────────────────────────────────────────
.vscode/*
# Keep C/C++ IntelliSense config
!.vscode/c_cpp_properties.json

# ─────────────────────────────────────────────
#  OS-generated files
# ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ─────────────────────────────────────────────
#  Editor / IDE temporary files
# ─────────────────────────────────────────────
*~
*.swp
*.swo
*.bak
*.tmp